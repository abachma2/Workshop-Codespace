<!--
This input file models the transition from EG 01 (thermal, 
critical reactors with a once through fuel cycle) to 
EG 23 (fast, critical reactors with U/Pu continuous 
recycle). 

The simulation models 2000 to 2100, with the 
transition starting in 2050, jsut to have round 
numbers. 
-->

<simulation>
    <control>
        <!-- 2000-2100 with the default 
         time step of 1/12 of  year -->
        <duration>1200</duration>
        <startmonth>1</startmonth>
        <startyear>2000</startyear>
    </control>

  <!-- Loading in the archetypes we need -->
  <archetypes>
    <spec>
      <lib>cycamore</lib>
      <name>Source</name>
    </spec>
    <spec>
      <lib>cycamore</lib>
      <name>Sink</name>
    </spec> 
    <spec>
      <lib>cycamore</lib>
      <name>Reactor</name>
    </spec>
    <spec>
      <lib>cycamore</lib>
      <name>Mixer</name>
    </spec>
    <spec>
      <lib>agents</lib>
      <name>NullRegion</name>
    </spec>
    <spec>
      <lib>agents</lib>
      <name>NullInst</name>
    </spec>
    <spec>
      <lib>cycamore</lib>
      <name>Separations</name>
    </spec>
    <spec>
      <lib>cycamore</lib>
      <name>DeployInst</name>
    </spec>
    <spec>
      <lib>cycamore</lib>
      <name>Enrichment</name>
    </spec>
    <spec>
      <lib>cycamore</lib>
      <name>Storage</name>
    </spec>
  </archetypes>

 <!-- Defining each of the prototypes -->
  <facility>
    <name>Mine</name>
    <config>
      <Source>
        <outcommod>natl_u</outcommod>
        <outrecipe>natl_u_recipe</outrecipe>
        <!-- optional parameters -->
        <throughput>1E299</throughput>
      </Source>
    </config>
  </facility>

  <facility>
    <name>Enrichment</name>
    <config>
      <Enrichment>
        <feed_commod>natl_u</feed_commod>
        <feed_recipe>natl_u_recipe</feed_recipe>
        <product_commod>fresh_lwr_fuel</product_commod>
        <tails_assay>0.003</tails_assay>
        <tails_commod>tailings</tails_commod>
        <!-- optional parameters -->
        <swu_capacity>1E100</swu_capacity>
        <initial_feed>1E100</initial_feed>
      </Enrichment>
    </config>
  </facility>

  <facility>
    <!-- Westinghouse Fuel Mass 90200 kg-->
    <name>LWR</name>
    <lifetime>960</lifetime>
    <config>
      <Reactor>
        <fuel_inrecipes>  
          <val>fresh_lwr_fuel_recipe</val>         
        </fuel_inrecipes>
        <fuel_outrecipes> 
          <val>used_lwr_fuel_recipe</val>   
        </fuel_outrecipes>
        <fuel_incommods>  
          <val>fresh_lwr_fuel</val>                
        </fuel_incommods>
        <fuel_outcommods> 
          <val>used_lwr_fuel</val>          
        </fuel_outcommods>
        <fuel_prefs>      
          <val>1.0</val>                
        </fuel_prefs>
        <cycle_time>18</cycle_time>
        <refuel_time>1</refuel_time>
        <assem_size>30160</assem_size>
        <n_assem_core>3</n_assem_core>
        <n_assem_batch>1</n_assem_batch>
        <power_cap>1000</power_cap>
      </Reactor>
    </config>
  </facility>

  <facility>
      <name>UOX_Cooling_Pool</name>
      <!-- Spent UOX Fuel Spends 3 years (36 timesteps)
      in NPP pools prior to process -->
      <config>
        <Storage>
          <in_commods>
            <val>used_lwr_fuel</val>
          </in_commods>
          <out_commods>
            <val>cool_used_lwr_fuel</val>
          </out_commods>
          <residence_time>36</residence_time>
          <!-- optional parameters -->
          <throughput>1E299</throughput>
          <max_inv_size>1E299</max_inv_size>
        </Storage>
      </config>
  </facility>

  <facility>
    <name>UOX_Reprocessing</name>
    <config>
      <Separations>
        <feed_commods>   
          <val>cool_used_lwr_fuel</val> 
        </feed_commods>
        <feed_commod_prefs> 
          <val>1.0</val> 
        </feed_commod_prefs>
        <feed_recipe>used_lwr_fuel_recipe</feed_recipe>
        <feedbuf_size>1E100</feedbuf_size>
        <throughput>1E100</throughput>
        <leftover_commod>uox_reprocess_waste</leftover_commod>
        <leftoverbuf_size>1E100</leftoverbuf_size>
        <streams>
          <item>
            <commod>separated_uox_Pu</commod>
            <info>
              <buf_size>1E100</buf_size>
              <efficiencies>
                <item>
                  <comp>Pu</comp> 
                  <eff>.998</eff>
                </item>
              </efficiencies>
            </info>
          </item>
          <item>
            <commod>separated_uox_U</commod>
            <info>
              <buf_size>1E100</buf_size>
              <efficiencies>
                <item>
                  <comp>U</comp> 
                  <eff>.998</eff>
                </item>
              </efficiencies>
            </info>
          </item>
        </streams>
      </Separations>
    </config>
  </facility>

  <facility>
    <name>SFR_Mixer</name>
    <config>
      <Mixer>
        <in_streams>
          <stream>
            <!-- can use plutonium separated from LWR or SFR fuel -->
            <info>
              <mixing_ratio>0.128996341</mixing_ratio>
              <buf_size>1e100</buf_size>
            </info>
            <commodities>
              <item>
                <commodity>separated_uox_Pu</commodity>
                <pref>1.0</pref>
              </item>
              <item>
                <commodity>separated_sfr_Pu</commodity>
                <pref>2.0</pref>
              </item>                        
            </commodities>
          </stream>
          <stream>
            <!-- can use uranium separated from LWR or SFR fuel -->
            <info>
              <mixing_ratio>0.714003659</mixing_ratio>
              <buf_size>1e100</buf_size>
            </info>
            <commodities>
              <item>
                <commodity>uox_U</commodity>
                <pref>1.0</pref>
              </item>
              <item>
                <commodity>sfr_U</commodity>
                <pref>1.0</pref>
              </item>                        
            </commodities>
          </stream>
          <!-- can top off with enrichment tailings or natural 
           uranium -->
          <stream>
            <info>
              <mixing_ratio>0.157</mixing_ratio>
              <buf_size>1e100</buf_size>
            </info>
            <commodities>
              <item>
                <commodity>tailings</commodity>
                <pref>2.0</pref>
              </item>
              <item>
                <commodity>natl_u</commodity>
                <pref>1.0</pref>
              </item>
            </commodities>
          </stream>
       </in_streams>
       <out_commod>fresh_sfr_fuel</out_commod>
       <out_buf_size>1e100</out_buf_size>
       <throughput>1e100</throughput>
      </Mixer>
    </config>
  </facility> 

  <facility>
      <name>SFR</name>
      <lifetime>960</lifetime>
      <config>
        <Reactor>
          <fuel_inrecipes>  
            <val>fresh_sfr_fuel_recipe</val>       
          </fuel_inrecipes>
          <fuel_outrecipes> 
            <val>used_sfr_fuel_recipe</val>  
          </fuel_outrecipes>
          <fuel_incommods>  
            <val>fresh_sfr_fuel</val>                   
          </fuel_incommods>
          <fuel_outcommods> 
            <val>used_sfr_fuel</val>             
          </fuel_outcommods>
          <fuel_prefs>      
            <val>1.0</val>                   
          </fuel_prefs>
          <cycle_time>14</cycle_time>
          <refuel_time>1</refuel_time>
          <assem_size>5867</assem_size>
          <n_assem_core>3</n_assem_core>
          <n_assem_batch>1</n_assem_batch>
          <power_cap>400</power_cap>
        </Reactor>
      </config>
  </facility>

  <facility>
      <name>SFR_Cooling_Pool</name>
      <!-- Spent Fuel Spends 3 years (36 timesteps) 
       in NPP pools prior to process -->
      <config>
        <Storage>
          <in_commods>
            <val>uSed_sfr_fuel</val>
          </in_commods>
          <out_commods>
            <val>cool_used_sfr_fuel</val>
          </out_commods>
          <residence_time>36</residence_time>
          <!-- optional parameters -->
          <throughput>1E299</throughput>
          <max_inv_size>1E299</max_inv_size>
        </Storage>
      </config>
  </facility>

  <facility>
    <name>SFR_Reprocessing</name>
    <config>
      <Separations>
        <feed_commods>   
          <val>cool_used_sfr_fuel</val>  
        </feed_commods>
        <feed_commod_prefs> 
          <val>2.0</val> 
        </feed_commod_prefs>
        <feedbuf_size>1E100</feedbuf_size>
        <throughput>1E100</throughput>
        <leftover_commod>sfr_reprocess_waste</leftover_commod>
        <leftoverbuf_size>1E100</leftoverbuf_size>
        <streams>
          <item>
            <commod>separated_sfr_Pu</commod>
            <info>
              <buf_size>1E100</buf_size>
              <efficiencies>
                <item>
                  <comp>Pu</comp> 
                  <eff>.998</eff>
                </item>
              </efficiencies>
            </info>
          </item>
          <item>
            <commod>separated_sfr_U</commod>
            <info>
              <buf_size>1E100</buf_size>
              <efficiencies>
                <item>
                  <comp>U</comp> 
                  <eff>.998</eff>
                </item>
              </efficiencies>
            </info>
          </item>
        </streams>
      </Separations>
    </config>
  </facility>

  <facility>
    <name>Waste_Repository</name>
    <config>
      <Sink>
        <in_commods>
          <val>tailings</val>
          <val>uox_reprocess_waste</val>
          <val>sfr_reprocess_waste</val>
        </in_commods>
        <!-- optional parameters -->
        <capacity>1E299</capacity>
      </Sink>
    </config>
  </facility>

<!-- Region -->

  <region>
    <config>
      <NullRegion/>
    </config>
    <institution>
      <config>
        <NullInst/>
      </config>
      <initialfacilitylist>
        <!-- facilities that we want deployed at the 
         beginning of the simulation (i.g., time step 0). -->
        <entry>
          <number>1</number>
          <prototype>Mine</prototype>
        </entry>
        <entry>
          <number>1</number>
          <prototype>Waste_Repository</prototype>
        </entry>
        <entry>
          <number>1</number>
          <prototype>Enrichment</prototype>
        </entry>

        <!-- MIXERS -->
        <entry>
          <number>1</number>
          <prototype>SFR_Mixer</prototype>
        </entry>

        <!-- POOLS -->
        <entry>
          <number>1</number>
          <prototype>SFR_Cooling_Pool</prototype>
        </entry>
        <entry>
          <number>1</number>
          <prototype>UOX_Cooling_Pool</prototype>
        </entry>

        <!-- REPROCESSING PLANTS -->
        <entry>
          <number>1</number>
          <prototype>UOX_Reprocessing</prototype>
        </entry>
        <entry>
          <number>1</number>
          <prototype>SFR_Reprocessing</prototype>
        </entry>
        
      </initialfacilitylist>
      <name>Initial_Facilities</name>
    </institution>
    <!-- Define a second instritution to define when the 
     LWRs are deployed, at time steps throughout the 
     simulation -->
    <institution>
      <name>LWR_Institution</name>
      <config>
        <DeployInst>
          <build_times>
            <!-- what time to deploy a prototype-->
            <val>12</val>
            <val>24</val>
            <val>36</val>
            <val>48</val>
            <val>60</val>
            <val>72</val>
            <val>84</val>
            <val>96</val>
            <val>108</val>
            <val>120</val>
          </build_times>
          <n_build>
            <!-- how many prototypes to deploy, with 
             the order mathcing that of the `build_times`
             input parameters-->
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
          </n_build>
          <prototypes>
            <!-- which prototype or deploy at each 
             time identified, with the order mathcing 
             that of the `build_times` input -->
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
            <val>LWR</val>
          </prototypes>
       </DeployInst>
      </config>
    </institution>
    <!-- Third institution to define when the SFR prototype 
     gets deployed -->
    <institution>
      <name>SFR_Institution</name>
      <config>
        <DeployInst>
          <build_times>
            <!-- what time to deploy a prototype-->
            <val>600</val>
            <val>612</val>
            <val>624</val>
            <val>636</val>
            <val>648</val>
            <val>660</val>
            <val>672</val>
            <val>684</val>
            <val>696</val>
            <val>708</val>
          </build_times>
          <n_build>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
            <val>2</val>
          </n_build>
          <prototypes>
            <!-- which prototype or deploy at each 
             time identified, with the order mathcing 
             that of the `build_times` input -->
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
            <val>SFR</val>
          </prototypes>
        </DeployInst>
      </config>
     </institution>
    <name>USA</name>
  </region>

<!-- Recipes - these are determined outside of the 
 Cyclus simulation -->
